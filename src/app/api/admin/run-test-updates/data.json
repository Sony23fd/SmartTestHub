  ],
  "qAdult": [
    {
      "text": "Бусдыг ойлгох, тэдний бодлыг ойлгоход надад хүндрэлтэй байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би төлөвлөгөөнөөс гадуурх гэнэтийн өөрчлөлтөд дургүй.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би нийгмийн идэвхи оролцоо сайтай бөгөөд найзтай болоход амархан байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 0
        },
        {
          "text": "Үгүй",
          "score": 1
        }
      ]
    },
    {
      "text": "Би олон зүйл гэхээс илүүтэй нэг зүйлд илүү сонирхолтой байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би танихгүй хүнтэй ярихад эвгүй байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би тодорхой дүрэм, журам баримтлах дуртай.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би бусдын олж хардаггүй маш нарийн зүйлсийг анзаардаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би харилцан ярианы үеэр нүдрүү харахаас зайлсхийдэг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Надад шууд бус яриа, сарказмыг ойлгоход хэцүү байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би хурц гэрэл, чанга чимээнд тавгүйтдэг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би олны цуглаан, тэдэнтэй харилцан ярианд ороход тухгүй байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би хошигнол ойлгохдоо муу.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би олуулаа биш ганцаараа байхдаа тухтай байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би нэг хөдөлгөөнийг давтаж хийдэг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Миний өдөр тутмын хийдэг зүйлсд саад учирахад дургүйцдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Олон нийтийн газар бусдын хариу үйлдлийг урьдчилан таамаглахад хэцүү байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би төлөвлөгөөнд гэнэтийн өөрчлөлт ороход хэвийн ханддаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 0
        },
        {
          "text": "Үгүй",
          "score": 1
        }
      ]
    },
    {
      "text": "Би бусдын нүүрний хувирлыг хурдан хүлээж авч ойлгодог.",
      "options": [
        {
          "text": "Тийм",
          "score": 0
        },
        {
          "text": "Үгүй",
          "score": 1
        }
      ]
    },
    {
      "text": "Би багаар гэхээс илүү ганцаараа ажиллах дуртай.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би хүмүүстэй өргөн сэдвээр ярилцах дуртай.",
      "options": [
        {
          "text": "Тийм",
          "score": 0
        },
        {
          "text": "Үгүй",
          "score": 1
        }
      ]
    },
    {
      "text": "Би бусадтай нөхөрлөхөд бэрхшээлтэй байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би өөрийгөө бусдаас өөр гэж мэдэрдэг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би давтамжтай зан үйлдэл хийх дуртай.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би дохио зангаа ойлгохдоо муу.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би томоохон арга хэмжээнд оролцох дуртай.",
      "options": [
        {
          "text": "Тийм",
          "score": 0
        },
        {
          "text": "Үгүй",
          "score": 1
        }
      ]
    },
    {
      "text": "Зарим зүйлийг ойлгоход цаг хугацаа их ордог.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би сэтгэл хөөрлийн ярианаас илүү шууд яриаг ойлгодог.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би бусадтай амархан ойлголцдог.",
      "options": [
        {
          "text": "Тийм",
          "score": 0
        },
        {
          "text": "Үгүй",
          "score": 1
        }
      ]
    },
    {
      "text": "Бусдын хандлагыг ойлгохдоо муу.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би харилцан ярианд хэзээ миний ярих ээлж гэдэгээ сайн мэдэхгүй байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би нийгмийн харилцааны дараа маш их ядарж тухгүйтдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би нэгэн зэрэг олон зүйлс хийж чаддаггүй.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би олон нийтийн газар уур бухимдлаа хянаж чаддаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 0
        },
        {
          "text": "Үгүй",
          "score": 1
        }
      ]
    },
    {
      "text": "Би хувцасны материал болон хоолны амтанд эмзэг, мэдрэг байдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би шинэ хоол туршиж үзэх дуртай.",
      "options": [
        {
          "text": "Тийм",
          "score": 0
        },
        {
          "text": "Үгүй",
          "score": 1
        }
      ]
    },
    {
      "text": "Би хээг нарийн анзаарах авьяастай.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би цөөн үгээр ярих дуртай.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би ойлгомжтой давтамжит даалгавар хийх дуртай.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би шинэ орчинд хурдан дасан зохицдог.",
      "options": [
        {
          "text": "Тийм",
          "score": 0
        },
        {
          "text": "Үгүй",
          "score": 1
        }
      ]
    },
    {
      "text": "Би бусдын шуурч байгаа зүйлд автдаггүй.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Бичигдээгүй олон нийтийн дүрэм, журмыг сахихдаа муу. Жишээлбэл: Олон нийтийн газар соёлтой, хүнтэй эелдэг харьцах, чанга дуу чимээ гаргаж болохгүй гэх мэт.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Танихгүй хүнтэй ярихдаа сандардаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Өөрийн сэтгэл хөдлөлөө бусадтай хуваалцаж чаддаггүй.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би нэг зүйлд маш их автдаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Заримдаа хүмүүс намайг бүдүүлэг зан авир гаргалаа гэдэг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би хүмүүсийн талаар бус юмсын талаар мэдэхийг хүсдэг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Би он, сар, тоо зэрэгт маш их татагддаг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    },
    {
      "text": "Хүмүүс намайг нэг зүйлээ давтаж ярьдаг гэдэг.",
      "options": [
        {
          "text": "Тийм",
          "score": 1
        },
        {
          "text": "Үгүй",
          "score": 0
        }
      ]
    }
  ]
